    {
      "@id": "https://ssbd.riken.jp/repository/ssbd-repos-000236/",
      "@type": "Dataset",
      "identifier": "ssbd-repos-000236",
      "name": "Cell membrane images, restored images, and segmentation results of 52 C. elegans embryos.",
      "description": "We performed 3D timelapse imaging of 52 embryos, in which the cell membrane is labeled with green fluorescent protein (GFP), for two hours from the two-cell stage. An image restoration method based on deep learning was applied to improve the image quality. An image processing method called BCOMS (Biologically Constrained Optimization-based cell Membrane Segmentation) was applied and the cellular regions were segmented.",
      "datePublished": "2022-06-30",
